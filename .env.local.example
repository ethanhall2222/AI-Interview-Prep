# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="service-role-key-if-needed"

# OpenAI
OPENAI_API_KEY="sk-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEV_MODE="1"
ADMIN_EMAILS="admin@yourorg.com,second-admin@yourorg.com"

# Airtable Job Posting Sync
AIRTABLE_PAT="patXXXX"
AIRTABLE_BASE_ID="appXXXX"
AIRTABLE_TABLE_NAME="JobPostings"
JOB_SOURCE_URLS="https://boards.greenhouse.io/example/jobs
https://jobs.lever.co/example
https://jobs.ashbyhq.com/example"

# Local Supabase (free, self-hosted)
# Copy values from: supabase status -o env
# NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
# SUPABASE_SERVICE_ROLE_KEY="..."
